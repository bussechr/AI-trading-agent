<UserControl x:Class="TradingAgent.Dashboard.App.Views.BridgeQosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PaneTitleText}" Text="Bridge QoS" Margin="0,0,0,6" />

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Text="Pending Queue" />
                    <TextBlock Style="{StaticResource MetricValueText}" Text="{Binding PendingCount}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Text="ACK Timeout 5m" />
                    <TextBlock Style="{StaticResource MetricValueText}" Text="{Binding AckTimeoutRate, StringFormat=P2}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Text="Queue->Terminal p95" />
                    <TextBlock Style="{StaticResource MetricValueText}" Text="{Binding QueueP95Ms, StringFormat=F0}"
                               Foreground="{DynamicResource BrushAccent}" />
                </StackPanel>
            </Border>
        </Grid>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ErrorBudgetRows}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Error Budget Key" Binding="{Binding Key}" Width="3*" />
                <DataGridTextColumn Header="Count" Binding="{Binding Value}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
