{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fxstack.local/schemas/orchestration/version_bundle.schema.json",
  "title": "VersionBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_version",
    "model_bundle_version",
    "orchestrator_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string"
    },
    "model_bundle_version": {
      "type": "string"
    },
    "orchestrator_version": {
      "type": "string"
    }
  }
}
