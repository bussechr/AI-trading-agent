fx-quant-stack/artifacts_shadow/
mlruns/

# Test artifacts
.hypothesis/
fx-quant-stack/.hypothesis/
# Doubled-path quirk: tests sometimes resolve `fx-quant-stack/artifacts/...`
# relative to the fx-quant-stack/ CWD, creating fx-quant-stack/fx-quant-stack/.
fx-quant-stack/fx-quant-stack/

# Keep requirements
!requirements.txt
