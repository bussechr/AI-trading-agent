.cursorindexingignore

# OS
.DS_Store
Thumbs.db

# graph / generated images (keep docs/ images committable)
data/**/*.png
outputs/**/*.png

# Generated text files (keep docs/ text committable)
data/**/*.txt
outputs/**/*.txt

# PDF files (keep docs/ PDFs committable)
data/**/*.pdf
outputs/**/*.pdf

# Frontend
node_modules
.next/
*.tsbuildinfo

# .NET build outputs
**/bin/
**/obj/

# Outputs
artifacts/
outputs/
DevelopmentTrading
data/state/
logs/
docs/canary_*.json
docs/canary_*.md
docs/backtests/
docs/e2e/
docs/audit/

# Database files (users will have their own local databases)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Alembic (keep migration files, but ignore generated/cache files)
app/backend/alembic/versions/__pycache__/

# MQL4
*.ex4

# Logs — keep all root-level and nested logs out of the repo
*.log
*.log.[0-9]*
logs/**
bridge-start.*
dashboard-*.log
runtime-start.*

# Data
data/raw/
data/heston/
data/fx_minis/
fx-quant-stack/data/
fx-quant-stack/artifacts/
