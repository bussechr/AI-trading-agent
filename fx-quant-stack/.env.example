# Research data source
FXSTACK_DATA_PROVIDER=dukascopy
FXSTACK_DUKASCOPY_SOURCE_ROOT=fx-quant-stack/data/dukascopy
FXSTACK_DUKASCOPY_FILE_PATTERN={pair}_{granularity}.csv

# Runtime storage (Postgres)
FXSTACK_DATABASE_URL=postgresql+psycopg://fx:fx@localhost:5432/fxstack

# MT4 bridge compatibility source for execution-time quotes
MT4_BRIDGE_URL=http://127.0.0.1:58710

# Runtime settings
FXSTACK_COMMAND_TTL_SECS=120
FXSTACK_DEFAULT_SESSION_ID=default
FXSTACK_PG_SERVICE_NAME=
FXSTACK_START_PROFILE=staged_safe
FXSTACK_RUN_FAST_GATE=0
FXSTACK_RUN_SHADOW_24H=0
FXSTACK_ALLOW_SQLITE=0
FXSTACK_REQUIRE_ACTIVE_MODELS=1
FXSTACK_PAIRS=EURUSD,GBPUSD,USDJPY,USDCHF,USDCAD,AUDUSD,NZDUSD,EURJPY
FXSTACK_INTRADAY_TIMEFRAME=M5
FXSTACK_SWING_TIMEFRAME=D
FXSTACK_REGIME_TIMEFRAME=H4
FXSTACK_MAX_PAIR_POSITIONS=1
FXSTACK_MAX_TOTAL_POSITIONS=6
FXSTACK_DEFAULT_ORDER_LOTS=0.10
FXSTACK_EQUITY_LOTS_PER_USD=0.00004
FXSTACK_MIN_ORDER_LOTS=0.01
FXSTACK_ORDER_LOT_STEP=0.01
FXSTACK_MAX_ORDER_LOTS=0
FXSTACK_MAX_ALLOWED_SPREAD_BPS=2.5
FXSTACK_MIN_EXPECTED_EDGE_BPS=3.0
FXSTACK_MODEL_ACTIVATION_MANIFEST=fx-quant-stack/artifacts/active_models.json
FXSTACK_REGISTRY_ROOT=fx-quant-stack/artifacts/registry
FXSTACK_REQUEUE_AGE_SECS=90
FXSTACK_DB_CONNECT_RETRIES=5
FXSTACK_REQUIRE_CUDA=1
FXSTACK_DEEP_MODEL_STALE_HOURS=24
FXSTACK_SWING_MODEL_POLICY=transformer_primary_xgb_fallback
FXSTACK_INTRADAY_MODEL_POLICY=tcn_primary_xgb_fallback
FXSTACK_TCN_WINDOW_SIZE=128
FXSTACK_TRANSFORMER_WINDOW_SIZE=96
FXSTACK_DEEP_TRAIN_EPOCHS=5
FXSTACK_DEEP_BATCH_SIZE=64
