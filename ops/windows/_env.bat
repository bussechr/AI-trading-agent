@echo off
setlocal

set "ROOT=%~dp0\..\.."
for %%I in ("%ROOT%") do set "ROOT=%%~fI"
cd /d "%ROOT%"

if exist "%ROOT%\ops\windows\installed_env.bat" call "%ROOT%\ops\windows\installed_env.bat"

if not defined FXSTACK_PACKAGE_MODE set "FXSTACK_PACKAGE_MODE=0"
if not defined FXSTACK_DATABASE_URL set "FXSTACK_DATABASE_URL=postgresql+psycopg://fx:fx@localhost:5432/fxstack"
if not defined FXSTACK_PAIRS set "FXSTACK_PAIRS=EURUSD,USDJPY,GBPUSD,AUDUSD,USDCHF,USDCAD,NZDUSD,EURJPY,EURGBP,GBPJPY,EURCHF,AUDJPY,EURAUD,CADJPY,CHFJPY,GBPCHF,EURCAD,GBPCAD"
if not defined FXSTACK_DATA_PROVIDER set "FXSTACK_DATA_PROVIDER=dukascopy"
if not defined FXSTACK_DUKASCOPY_SOURCE_ROOT set "FXSTACK_DUKASCOPY_SOURCE_ROOT=%ROOT%\fx-quant-stack\data\dukascopy"
if not defined FXSTACK_DUKASCOPY_FILE_PATTERN set "FXSTACK_DUKASCOPY_FILE_PATTERN={pair}_{granularity}.csv"
if not defined FXSTACK_ALLOW_SQLITE set "FXSTACK_ALLOW_SQLITE=0"
if not defined FXSTACK_LIVE_ALLOW_SQLITE_FALLBACK set "FXSTACK_LIVE_ALLOW_SQLITE_FALLBACK=0"
if not defined FXSTACK_START_PROFILE set "FXSTACK_START_PROFILE=staged_safe"
if not defined FXSTACK_RUN_FAST_GATE set "FXSTACK_RUN_FAST_GATE=0"
if not defined FXSTACK_RUN_SHADOW_24H set "FXSTACK_RUN_SHADOW_24H=0"
if not defined FXSTACK_REQUIRE_CUDA set "FXSTACK_REQUIRE_CUDA=0"
if not defined FXSTACK_DEEP_MODEL_STALE_HOURS set "FXSTACK_DEEP_MODEL_STALE_HOURS=24"
if not defined FXSTACK_FORCE_WEEKLY_RETRAIN_DAY set "FXSTACK_FORCE_WEEKLY_RETRAIN_DAY=saturday"
if not defined FXSTACK_WEEKLY_FULL_RETRAIN_TIME set "FXSTACK_WEEKLY_FULL_RETRAIN_TIME=03:00"
if not defined FXSTACK_WEEKLY_AUTO_ACTIVATE set "FXSTACK_WEEKLY_AUTO_ACTIVATE=1"
if not defined FXSTACK_MODEL_LOAD_TIMEOUT_SECS set "FXSTACK_MODEL_LOAD_TIMEOUT_SECS=12"
if not defined FXSTACK_RUNTIME_STARTUP_TIMEOUT_SECS set "FXSTACK_RUNTIME_STARTUP_TIMEOUT_SECS=300"
if not defined FXSTACK_RUNTIME_STARTUP_PROGRESS_STALE_SECS set "FXSTACK_RUNTIME_STARTUP_PROGRESS_STALE_SECS=45"
if not defined FXSTACK_PROCESS_EXIT_WAIT_SECS set "FXSTACK_PROCESS_EXIT_WAIT_SECS=10"
if not defined FXSTACK_SWING_MODEL_POLICY set "FXSTACK_SWING_MODEL_POLICY=xgb_only"
if not defined FXSTACK_INTRADAY_MODEL_POLICY set "FXSTACK_INTRADAY_MODEL_POLICY=xgb_only"
if not defined FXSTACK_MIN_SWING_PROB set "FXSTACK_MIN_SWING_PROB=0.58"
if not defined FXSTACK_MIN_ENTRY_PROB set "FXSTACK_MIN_ENTRY_PROB=0.62"
if not defined FXSTACK_MIN_TRADE_PROB set "FXSTACK_MIN_TRADE_PROB=0.60"
if not defined FXSTACK_MAX_ALLOWED_SPREAD_BPS set "FXSTACK_MAX_ALLOWED_SPREAD_BPS=2.5"
if not defined FXSTACK_MIN_EXPECTED_EDGE_BPS set "FXSTACK_MIN_EXPECTED_EDGE_BPS=3.0"
if not defined FXSTACK_EQUITY_LOTS_PER_USD set "FXSTACK_EQUITY_LOTS_PER_USD=0.00004"
if not defined FXSTACK_MIN_ORDER_LOTS set "FXSTACK_MIN_ORDER_LOTS=0.01"
if not defined FXSTACK_ORDER_LOT_STEP set "FXSTACK_ORDER_LOT_STEP=0.01"
if not defined FXSTACK_MAX_ORDER_LOTS set "FXSTACK_MAX_ORDER_LOTS=0"
if not defined FXSTACK_BRIDGE_STALE_HEARTBEAT_SECS set "FXSTACK_BRIDGE_STALE_HEARTBEAT_SECS=30"
if not defined FXSTACK_BRIDGE_STALE_TICK_SECS set "FXSTACK_BRIDGE_STALE_TICK_SECS=30"
if not defined FXSTACK_BRIDGE_API_KEY set "FXSTACK_BRIDGE_API_KEY="
if not defined FXSTACK_RUNTIME_ALLOW_CREATE_ALL set "FXSTACK_RUNTIME_ALLOW_CREATE_ALL=0"
if not defined FXSTACK_STOP_KILL_ALL_PYTHON set "FXSTACK_STOP_KILL_ALL_PYTHON=0"
if not defined FXSTACK_ENABLE_LIFECYCLE_ACTIONS set "FXSTACK_ENABLE_LIFECYCLE_ACTIONS=1"
if not defined FXSTACK_ENABLE_ADJUST_ACTIONS set "FXSTACK_ENABLE_ADJUST_ACTIONS=0"
if not defined TRADER_BRIDGE_IMPL set "TRADER_BRIDGE_IMPL=fxstack"
if not defined TRADER_RUNTIME_IMPL set "TRADER_RUNTIME_IMPL=fxstack"
if not defined TRADER_BRIDGE_PORT set "TRADER_BRIDGE_PORT=58710"

set "FXSTACK_PAIRS_SP=%FXSTACK_PAIRS:,= %"

set "PY_EXE="
set "ACTIVE_VENV_FILE=%ROOT%\fx-quant-stack\.venv_win.active"
set "ACTIVE_VENV_DIR="
if exist "%ACTIVE_VENV_FILE%" for /f "usebackq delims=" %%V in ("%ACTIVE_VENV_FILE%") do set "ACTIVE_VENV_DIR=%%V"
if defined TRADER_PYTHON_EXE if exist "%TRADER_PYTHON_EXE%" set "PY_EXE=%TRADER_PYTHON_EXE%"
if not defined PY_EXE if exist "%ROOT%\runtime\python\python.exe" set "PY_EXE=%ROOT%\runtime\python\python.exe"
if not defined PY_EXE if defined ACTIVE_VENV_DIR if exist "%ROOT%\fx-quant-stack\%ACTIVE_VENV_DIR%\Scripts\python.exe" set "PY_EXE=%ROOT%\fx-quant-stack\%ACTIVE_VENV_DIR%\Scripts\python.exe"
if not defined PY_EXE if exist "%ROOT%\fx-quant-stack\.venv_win\Scripts\python.exe" set "PY_EXE=%ROOT%\fx-quant-stack\.venv_win\Scripts\python.exe"
if not defined PY_EXE if exist "%LOCALAPPDATA%\Programs\Python\Python311\python.exe" set "PY_EXE=%LOCALAPPDATA%\Programs\Python\Python311\python.exe"
if not defined PY_EXE if exist "C:\Users\%USERNAME%\AppData\Local\Programs\Python\Python311\python.exe" set "PY_EXE=C:\Users\%USERNAME%\AppData\Local\Programs\Python\Python311\python.exe"
if not defined PY_EXE if exist "C:\Python311\python.exe" set "PY_EXE=C:\Python311\python.exe"
if not defined PY_EXE if exist "%ROOT%\fx-quant-stack\.venv\Scripts\python.exe" set "PY_EXE=%ROOT%\fx-quant-stack\.venv\Scripts\python.exe"
if not defined PY_EXE if exist "%ROOT%\.venv\Scripts\python.exe" set "PY_EXE=%ROOT%\.venv\Scripts\python.exe"
if not defined PY_EXE set "PY_EXE=python"

set "TRADER_PYTHON_EXE=%PY_EXE%"
set "PYTHONPATH=%ROOT%"
set "NODE_EXE_RESOLVED="
if defined NODE_EXE if exist "%NODE_EXE%" set "NODE_EXE_RESOLVED=%NODE_EXE%"
if not defined NODE_EXE_RESOLVED if exist "%ROOT%\runtime\node\node.exe" set "NODE_EXE_RESOLVED=%ROOT%\runtime\node\node.exe"
if not defined NODE_EXE_RESOLVED for /f "delims=" %%N in ('where node 2^>nul') do if not defined NODE_EXE_RESOLVED set "NODE_EXE_RESOLVED=%%N"
if not defined NODE_EXE_RESOLVED if exist "C:\Program Files\nodejs\node.exe" set "NODE_EXE_RESOLVED=C:\Program Files\nodejs\node.exe"
if defined NODE_EXE_RESOLVED set "NODE_EXE=%NODE_EXE_RESOLVED%"

endlocal & (
  set "ROOT=%ROOT%"
  set "FXSTACK_PACKAGE_MODE=%FXSTACK_PACKAGE_MODE%"
  set "FXSTACK_DATABASE_URL=%FXSTACK_DATABASE_URL%"
  set "FXSTACK_PAIRS=%FXSTACK_PAIRS%"
  set "FXSTACK_PAIRS_SP=%FXSTACK_PAIRS_SP%"
  set "FXSTACK_DATA_PROVIDER=%FXSTACK_DATA_PROVIDER%"
  set "FXSTACK_DUKASCOPY_SOURCE_ROOT=%FXSTACK_DUKASCOPY_SOURCE_ROOT%"
  set "FXSTACK_DUKASCOPY_FILE_PATTERN=%FXSTACK_DUKASCOPY_FILE_PATTERN%"
  set "FXSTACK_ALLOW_SQLITE=%FXSTACK_ALLOW_SQLITE%"
  set "FXSTACK_LIVE_ALLOW_SQLITE_FALLBACK=%FXSTACK_LIVE_ALLOW_SQLITE_FALLBACK%"
  set "FXSTACK_START_PROFILE=%FXSTACK_START_PROFILE%"
  set "FXSTACK_RUN_FAST_GATE=%FXSTACK_RUN_FAST_GATE%"
  set "FXSTACK_RUN_SHADOW_24H=%FXSTACK_RUN_SHADOW_24H%"
  set "FXSTACK_REQUIRE_CUDA=%FXSTACK_REQUIRE_CUDA%"
  set "FXSTACK_DEEP_MODEL_STALE_HOURS=%FXSTACK_DEEP_MODEL_STALE_HOURS%"
  set "FXSTACK_FORCE_WEEKLY_RETRAIN_DAY=%FXSTACK_FORCE_WEEKLY_RETRAIN_DAY%"
  set "FXSTACK_WEEKLY_FULL_RETRAIN_TIME=%FXSTACK_WEEKLY_FULL_RETRAIN_TIME%"
  set "FXSTACK_WEEKLY_AUTO_ACTIVATE=%FXSTACK_WEEKLY_AUTO_ACTIVATE%"
  set "FXSTACK_MODEL_LOAD_TIMEOUT_SECS=%FXSTACK_MODEL_LOAD_TIMEOUT_SECS%"
  set "FXSTACK_RUNTIME_STARTUP_TIMEOUT_SECS=%FXSTACK_RUNTIME_STARTUP_TIMEOUT_SECS%"
  set "FXSTACK_RUNTIME_STARTUP_PROGRESS_STALE_SECS=%FXSTACK_RUNTIME_STARTUP_PROGRESS_STALE_SECS%"
  set "FXSTACK_PROCESS_EXIT_WAIT_SECS=%FXSTACK_PROCESS_EXIT_WAIT_SECS%"
  set "FXSTACK_SWING_MODEL_POLICY=%FXSTACK_SWING_MODEL_POLICY%"
  set "FXSTACK_INTRADAY_MODEL_POLICY=%FXSTACK_INTRADAY_MODEL_POLICY%"
  set "FXSTACK_MIN_SWING_PROB=%FXSTACK_MIN_SWING_PROB%"
  set "FXSTACK_MIN_ENTRY_PROB=%FXSTACK_MIN_ENTRY_PROB%"
  set "FXSTACK_MIN_TRADE_PROB=%FXSTACK_MIN_TRADE_PROB%"
  set "FXSTACK_MAX_ALLOWED_SPREAD_BPS=%FXSTACK_MAX_ALLOWED_SPREAD_BPS%"
  set "FXSTACK_MIN_EXPECTED_EDGE_BPS=%FXSTACK_MIN_EXPECTED_EDGE_BPS%"
  set "FXSTACK_EQUITY_LOTS_PER_USD=%FXSTACK_EQUITY_LOTS_PER_USD%"
  set "FXSTACK_MIN_ORDER_LOTS=%FXSTACK_MIN_ORDER_LOTS%"
  set "FXSTACK_ORDER_LOT_STEP=%FXSTACK_ORDER_LOT_STEP%"
  set "FXSTACK_MAX_ORDER_LOTS=%FXSTACK_MAX_ORDER_LOTS%"
  set "FXSTACK_BRIDGE_STALE_HEARTBEAT_SECS=%FXSTACK_BRIDGE_STALE_HEARTBEAT_SECS%"
  set "FXSTACK_BRIDGE_STALE_TICK_SECS=%FXSTACK_BRIDGE_STALE_TICK_SECS%"
  set "FXSTACK_BRIDGE_API_KEY=%FXSTACK_BRIDGE_API_KEY%"
  set "FXSTACK_RUNTIME_ALLOW_CREATE_ALL=%FXSTACK_RUNTIME_ALLOW_CREATE_ALL%"
  set "FXSTACK_STOP_KILL_ALL_PYTHON=%FXSTACK_STOP_KILL_ALL_PYTHON%"
  set "FXSTACK_ENABLE_LIFECYCLE_ACTIONS=%FXSTACK_ENABLE_LIFECYCLE_ACTIONS%"
  set "FXSTACK_ENABLE_ADJUST_ACTIONS=%FXSTACK_ENABLE_ADJUST_ACTIONS%"
  set "TRADER_BRIDGE_IMPL=%TRADER_BRIDGE_IMPL%"
  set "TRADER_RUNTIME_IMPL=%TRADER_RUNTIME_IMPL%"
  set "TRADER_BRIDGE_PORT=%TRADER_BRIDGE_PORT%"
  set "TRADER_PYTHON_EXE=%TRADER_PYTHON_EXE%"
  set "NODE_EXE=%NODE_EXE%"
  set "PYTHONPATH=%PYTHONPATH%"
)

exit /b 0
