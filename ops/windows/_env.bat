if /I "%FXSTACK_SKIP_INSTALLED_ENV%"=="yes" set "LOAD_INSTALLED_ENV=0"
if "%LOAD_INSTALLED_ENV%"=="1" if exist "%ROOT%\ops\windows\installed_env.bat" call "%ROOT%\ops\windows\installed_env.bat"
if exist "%ROOT%\logs\active_stack_env.bat" call "%ROOT%\logs\active_stack_env.bat"
if exist "%ROOT%\logs\active_candidate_env.bat" call "%ROOT%\logs\active_candidate_env.bat"
if not defined FXSTACK_BRIDGE_API_KEY if defined TRADER_BRIDGE_API_KEY set "FXSTACK_BRIDGE_API_KEY=%TRADER_BRIDGE_API_KEY%"
if not defined FXSTACK_BRIDGE_AUTH_REQUIRED if defined TRADER_BRIDGE_AUTH_REQUIRED set "FXSTACK_BRIDGE_AUTH_REQUIRED=%TRADER_BRIDGE_AUTH_REQUIRED%"

